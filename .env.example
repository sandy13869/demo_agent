# ── Required ──────────────────────────────────────────────────────────────────
# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/crypto_prices

# ── Optional: server ──────────────────────────────────────────────────────────
# HTTP server port for REST API and Swagger UI (default: 3000)
PORT=3000

# Runtime environment: development | production | test (default: development)
NODE_ENV=development

# Comma-separated allowed CORS origins, or * for all (default: *)
CORS_ORIGIN=*

# Rate limiter: window in milliseconds (default: 900000 = 15 min)
RATE_LIMIT_WINDOW_MS=900000

# Rate limiter: max requests per window per IP (default: 100)
RATE_LIMIT_MAX=100

# ── Optional: logging ─────────────────────────────────────────────────────────
# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# ── Optional: CoinGecko client ────────────────────────────────────────────────
# CoinGecko API base URL (default: https://api.coingecko.com/api/v3)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Request timeout in milliseconds (default: 5000)
API_TIMEOUT_MS=5000

# Maximum retry attempts per fetch cycle (default: 3)
MAX_RETRIES=3
