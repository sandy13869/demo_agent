# MongoDB connection URI (required)
MONGODB_URI=mongodb://localhost:27017/crypto_prices

# Logging level: error | warn | info | debug (optional, default: info)
LOG_LEVEL=info

# CoinGecko API base URL (optional, uses public free endpoint by default)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# HTTP server port for REST API and Swagger UI (optional, default: 3000)
PORT=8000

# Request timeout in milliseconds (optional, default: 5000)
API_TIMEOUT_MS=5000

# Maximum retry attempts per fetch cycle (optional, default: 3)
MAX_RETRIES=3
